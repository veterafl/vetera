{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/site/index.html" },
    { "source": "/d/:slug", "destination": "/site/d/:slug.html" },
    { "source": "/dentists", "destination": "/site/dentists/index.html" },
    { "source": "/dentists/:letter", "destination": "/site/dentists/:letter.html" },
    { "source": "/sample-report", "destination": "/site/sample-report.html" },
    { "source": "/methodology", "destination": "/site/methodology.html" },
    { "source": "/faq", "destination": "/site/faq.html" },
    { "source": "/request", "destination": "/site/request.html" },
    { "source": "/terms", "destination": "/site/terms.html" },
    { "source": "/privacy", "destination": "/site/privacy.html" },
    { "source": "/thank-you", "destination": "/site/thank-you.html" },
    { "source": "/:path*", "destination": "/site/:path*" }
  ]
}
